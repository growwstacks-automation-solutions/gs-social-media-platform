VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

VITE_WEBHOOK_POST_GENERATION=https://your-n8n-host/webhook/post-generation
VITE_WEBHOOK_POST_REGENERATION=https://your-n8n-host/webhook/post-regeneration
VITE_WEBHOOK_POST_PUBLISHING=https://your-n8n-host/webhook/post-publishing
VITE_WEBHOOK_DELETE_RECORD=https://your-n8n-host/webhook/delete-record

VITE_IMAGEKIT_UPLOAD_URL=/api/imagekit-upload

# Server-only (no VITE_ prefix → NEVER bundled into the browser).
# Used by vite.config.js dev proxy to attach Basic Auth on uploads to ImageKit.
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
